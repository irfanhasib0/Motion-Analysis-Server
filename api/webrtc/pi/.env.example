# WebRTC Configuration
SIGNAL_WSS=wss://signal.example.com/ws/device
DEVICE_ID=dev1
DEVICE_TOKEN=CHANGE_ME_GENERATE_RANDOM_TOKEN

# Camera Configuration - Option 1: Individual components
# The publisher will construct RTSP URL from these
CAM_IP=192.168.1.100
CAM_USER=admin
CAM_PASS=password

# Camera Configuration - Option 2: Complete RTSP URL (overrides above)
# Use this for full control over RTSP parameters
# RTSP_URL=rtsp://admin:password@192.168.1.100:554/cam/realmonitor?channel=1&subtype=0&unicast=true&proto=Onvif

# Performance Tip: Use substream (subtype=1) for better performance on Pi 4
# Substream is typically lower resolution and may already be H.264
# RTSP_URL=rtsp://admin:password@192.168.1.100:554/cam/realmonitor?channel=1&subtype=1&unicast=true&proto=Onvif

# To test your camera streams:
# Main stream: ffprobe -rtsp_transport tcp "rtsp://admin:pass@192.168.1.100:554/cam/realmonitor?channel=1&subtype=0&unicast=true&proto=Onvif"
# Sub stream:  ffprobe -rtsp_transport tcp "rtsp://admin:pass@192.168.1.100:554/cam/realmonitor?channel=1&subtype=1&unicast=true&proto=Onvif"

# AI Stream Settings (for publisher_ai.py and ai_stream_server.py)
AI_W=854
AI_H=480
AI_FPS=10

# Optional: HTTP Server Port (defaults to 9000)
# HTTP_PORT=9000
